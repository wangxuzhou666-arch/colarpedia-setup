# Yourpedia setup tool — required environment variables.
#
# Copy this file to .env.local and fill in real values. .env.local is
# gitignored and never leaves your machine. On Vercel, set the same
# variables in Project Settings → Environment Variables.

# Anthropic API key for the LLM that parses uploaded résumés. Get one
# at https://console.anthropic.com/settings/keys. Free tier is enough
# for MVP traffic (Haiku 4.5 ~$0.005 per generation).
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: monthly cost alert threshold in USD. The endpoint logs a
# warning when the running total estimate crosses this. Set lower
# during dev, higher once you have real users. Default 20.
COST_ALERT_USD=20

# Optional: rate limit per IP per day. Default 10. Set to 0 to disable.
RATE_LIMIT_PER_DAY=10
